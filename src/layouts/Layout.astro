---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal music dashboard — track listening history, discover new music' } = Astro.props;

const pageTitle = `${title} — emomert/music`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />

  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{pageTitle}</title>
</head>
<body>
  <div class="min-h-screen flex flex-col max-w-5xl mx-auto px-5 py-8 md:py-12">
    <slot />
  </div>
</body>
</html>
