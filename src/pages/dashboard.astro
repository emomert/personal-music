---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import DashboardCharts from '../components/DashboardCharts.astro';
import { readFileSync } from 'fs';

let lastfm = null;
try {
  lastfm = JSON.parse(readFileSync('./data/lastfm.json', 'utf-8'));
} catch {}

const periodData = {
  last7days: {
    label: 'Last 7 Days',
    topArtists: lastfm?.topArtists_last7days || [],
    topTracks: lastfm?.topTracks_last7days || [],
    topAlbums: lastfm?.topAlbums_last7days || [],
  },
  lastMonth: {
    label: 'Last Month',
    topArtists: lastfm?.topArtists_lastMonth || [],
    topTracks: lastfm?.topTracks_lastMonth || [],
    topAlbums: lastfm?.topAlbums_lastMonth || [],
  },
  last3Months: {
    label: 'Last 3 Months',
    topArtists: lastfm?.topArtists_last3Months || [],
    topTracks: lastfm?.topTracks_last3Months || [],
    topAlbums: lastfm?.topAlbums_last3Months || [],
  },
  lastYear: {
    label: 'Last Year',
    topArtists: lastfm?.topArtists_lastYear || [],
    topTracks: lastfm?.topTracks_lastYear || [],
    topAlbums: lastfm?.topAlbums_lastYear || [],
  },
  allTime: {
    label: 'All Time',
    topArtists: lastfm?.topArtists_allTime || [],
    topTracks: lastfm?.topTracks_allTime || [],
    topAlbums: lastfm?.topAlbums_allTime || [],
  },
};
---

<Layout title="Dashboard" description="Interactive charts of your top artists, tracks, and albums">
  <Navigation />

  <main class="space-y-8 animate-section">
    <section>
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-2xl font-heading font-semibold text-navy">Dashboard</h1>
          <p class="text-sm text-slate-500 mt-1">Select a period to explore</p>
        </div>

        {/* Period selector */}
        <div class="flex flex-wrap gap-1.5" id="periodButtons" role="radiogroup" aria-label="Time period">
          {Object.entries(periodData).map(([key, data]) => (
            <button
              data-period={key}
              class:list={[
                'period-btn',
                key === 'last7days' ? 'active' : ''
              ]}
              role="radio"
              aria-checked={key === 'last7days' ? 'true' : 'false'}
            >
              {data.label}
            </button>
          ))}
        </div>
      </div>

      <DashboardCharts />
    </section>

    {/* Top Lists */}
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-200 bg-cream-dark/50">
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Top Artists</h3>
        </div>
        <div id="artistList" class="divide-y divide-slate-100">
        </div>
      </div>
      <div class="card overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-200 bg-cream-dark/50">
          <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Top Tracks</h3>
        </div>
        <div id="trackList" class="divide-y divide-slate-100">
        </div>
      </div>
    </section>
  </main>

  <footer class="mt-16 pt-8 border-t border-slate-200 text-xs text-slate-400">
    <span>Data refreshed daily via GitHub Actions</span>
  </footer>

  <script define:vars={{ periodData }}>
    window.__periodData = periodData;
    window.__initialPeriod = 'last7days';

    function renderLists(data) {
      const artistList = document.getElementById('artistList');
      const trackList = document.getElementById('trackList');
      if (!artistList || !trackList) return;

      artistList.innerHTML = data.topArtists.slice(0, 15).map((a, i) => `
        <div class="px-5 py-3 flex items-center gap-3 hover:bg-cream-dark/30 transition-colors duration-150">
          <span class="text-slate-400 font-mono text-sm w-6 text-right">${(i + 1).toString().padStart(2, '0')}</span>
          <div class="flex-1 min-w-0">
            <div class="text-navy font-medium truncate">${a.name}</div>
            <div class="text-xs text-slate-400">${Number(a.playcount).toLocaleString()} plays</div>
          </div>
          ${i < 3 ? `<span class="text-xs font-bold text-amber-500">★</span>` : ''}
        </div>
      `).join('');

      trackList.innerHTML = data.topTracks.slice(0, 15).map((t, i) => `
        <div class="px-5 py-3 flex items-center gap-3 hover:bg-cream-dark/30 transition-colors duration-150">
          <span class="text-slate-400 font-mono text-sm w-6 text-right">${(i + 1).toString().padStart(2, '0')}</span>
          <div class="flex-1 min-w-0">
            <div class="text-navy font-medium truncate">${t.name}</div>
            <div class="text-xs text-slate-400 truncate">${t.artist?.name || t.artist?.['#text'] || 'Unknown'}</div>
          </div>
          ${i < 3 ? `<span class="text-xs font-bold text-amber-500">★</span>` : ''}
        </div>
      `).join('');
    }

    function updateChartData() {
      const c = window.renderDashboardCharts;
      const d = window.__currentData;
      if (c && d) c(d);
    }

    function switchPeriod(key) {
      window.__currentData = window.__periodData[key];

      // Update button states
      document.querySelectorAll('#periodButtons button').forEach(btn => {
        if (btn.dataset.period === key) {
          btn.classList.add('active');
          btn.setAttribute('aria-checked', 'true');
        } else {
          btn.classList.remove('active');
          btn.setAttribute('aria-checked', 'false');
        }
      });

      renderLists(window.__currentData);
      updateChartData();
    }

    // Initialize — key fix: wait for Chart.js to register
    function initCharts() {
      if (window.renderDashboardCharts) {
        window.__currentData = window.__periodData[window.__initialPeriod];
        window.renderDashboardCharts(window.__currentData);
        renderLists(window.__currentData);
      } else {
        // Chart.js script hasn't loaded yet — retry
        setTimeout(initCharts, 100);
      }
    }

    // Bind buttons
    document.querySelectorAll('#periodButtons button').forEach(btn => {
      btn.addEventListener('click', () => switchPeriod(btn.dataset.period));
    });

    // Start rendering — with race condition fix via retry
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCharts);
    } else {
      initCharts();
    }
  </script>
</Layout>
