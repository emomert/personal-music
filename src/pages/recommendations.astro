---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { readFileSync } from 'fs';

let recs = null;
try {
  recs = JSON.parse(readFileSync('./data/recommendations.json', 'utf-8'));
} catch {}

const hasData = recs && recs.tracks && recs.tracks.length > 0;
const isHybrid = hasData && recs.source === 'hybrid_spotify_lastfm';
const isLegacySpotify = hasData && !recs.source; // old /recommendations output, kept for compatibility
const isSpotifyGrade = isHybrid || isLegacySpotify;
const isFallback = hasData && recs.source === 'lastfm_fallback';

const generatedDate = recs?.generatedAt
  ? new Date(recs.generatedAt).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const trackRecs = isLegacySpotify
  ? (recs.tracks || [])
  : (recs?.tracks?.filter(t => t.name) || []);

const artistRecs = isSpotifyGrade
  ? []
  : (recs?.tracks?.filter(t => !t.name && t.sourceArtist) || []);

function isPlaceholder(url) {
  return !url || url.includes('2a96cbd8b46e442fc41c2b86b821562f');
}

function initials(name) {
  return name?.split(' ').map(w => w[0]).join('').slice(0, 2) || '?';
}
---

<Layout title="Discover" description="Weekly music recommendations based on your listening history">
  <Navigation />

  <main class="space-y-8 animate-section">
    {/* Header */}
    <section>
      <h1 class="text-2xl font-heading font-semibold text-navy mb-1">Discover Weekly</h1>
      <p class="text-sm text-slate-500">
        {hasData && generatedDate
          ? `Generated on ${generatedDate} based on your recent listening.`
          : 'No recommendations generated yet. They update every Monday morning.'}
      </p>
      {recs?.seedArtists?.length > 0 && (
        <p class="text-xs text-slate-400 mt-2">
          Seed artists: {recs.seedArtists.join(', ')}
        </p>
      )}
    </section>

    {/* Engine banner */}
    {(isSpotifyGrade || isFallback) && (
      <div class="card p-4 flex items-start gap-3">
        <span class="text-xl shrink-0" aria-hidden="true">{isSpotifyGrade ? '🎯' : '♫'}</span>
        <div>
          <p class="font-semibold text-navy">
            {isHybrid
              ? 'Spotify Recommendations (Hybrid Engine)'
              : isLegacySpotify
                ? 'Spotify Algorithmic Recommendations'
                : 'Last.fm Similarity Engine'}
          </p>
          <p class="text-sm text-slate-500 mt-1">
            {isHybrid
              ? 'Last.fm collaborative similarity finds candidates from your taste; Spotify supplies real metadata and a genre-overlap boost ranks them.'
              : isLegacySpotify
                ? 'Generated from Spotify\'s audio analysis: danceability, energy, tempo, and collaborative filtering.'
                : 'Generated from Last.fm\'s listener network: people who love your top tracks also listen to these.'}
          </p>
          {isFallback && (
            <p class="text-xs text-slate-400 mt-2">
              Want richer recommendations with real album art? Add Spotify credentials to your GitHub repo secrets and the engine switches automatically.
            </p>
          )}
          {isHybrid && recs.seedGenres?.length > 0 && (
            <p class="text-xs text-slate-400 mt-2">
              Genres in the mix: {recs.seedGenres.slice(0, 6).join(', ')}
            </p>
          )}
        </div>
      </div>
    )}

    {/* Track Recommendations */}
    {trackRecs.length > 0 && (
      <section>
        <h2 class="text-lg font-heading font-semibold text-navy mb-4">
          {isSpotifyGrade ? 'Recommended Tracks' : 'Similar Tracks'}
          <span class="text-sm font-normal text-slate-400 ml-2">{trackRecs.length}</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {trackRecs.map((track, i) => (
            <div class="card p-4 group">
              <div class="flex items-start gap-4">
                {track.image && !isPlaceholder(track.image) ? (
                  <img src={track.image} alt={track.name} class="w-16 h-16 rounded-lg object-cover album-frame shrink-0" loading="lazy" />
                ) : (
                  <div class="w-16 h-16 bg-cream-dark rounded-lg flex flex-col items-center justify-center shrink-0 border border-slate-200">
                    <span class="text-sm font-bold text-amber-500">{initials(track.artist)}</span>
                    <span class="text-[9px] text-slate-400 mt-0.5">{initials(track.name)}</span>
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-xs text-amber-500 font-mono">#{i + 1}</span>
                    {track.spotifyUrl && (
                      <a href={track.spotifyUrl} target="_blank" rel="noopener noreferrer"
                         class="text-xs font-medium text-navy hover:text-amber-500 transition-colors shrink-0"
                         aria-label={`Open ${track.name} on Spotify`}>
                        Open ↗
                      </a>
                    )}
                  </div>
                  <h3 class="text-navy font-semibold truncate mt-1">{track.name}</h3>
                  <p class="text-slate-500 text-sm truncate">{track.artist}</p>
                  {track.album && <p class="text-slate-400 text-xs truncate">{track.album}</p>}
                  {track.sourceTrack && (
                    <p class="text-xs text-slate-400 mt-1">
                      Because you like: <span class="text-slate-500 font-medium">{track.sourceTrack}</span>
                    </p>
                  )}
                  {!track.sourceTrack && track.sourceArtist && (
                    <p class="text-xs text-slate-400 mt-1">
                      Fans of: <span class="text-slate-500 font-medium">{track.sourceArtist}</span>
                    </p>
                  )}
                  {track.previewUrl && (
                    <audio controls class="mt-2 w-full" preload="none" aria-label={`30-second preview of ${track.name}`}>
                      <source src={track.previewUrl} type="audio/mpeg" />
                    </audio>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* Similar Artists (fallback only) */}
    {artistRecs.length > 0 && (
      <section>
        <h2 class="text-lg font-heading font-semibold text-navy mb-4">
          Similar Artists
          <span class="text-sm font-normal text-slate-400 ml-2">{artistRecs.length}</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {artistRecs.map((item, i) => (
            <div class="card p-4 text-center group">
              <div class="w-16 h-16 bg-cream-dark rounded-full flex items-center justify-center mx-auto mb-3 border border-slate-200 group-hover:border-amber-300 transition-colors">
                <span class="text-lg font-bold text-navy font-heading">{initials(item.artist)}</span>
              </div>
              <h3 class="text-navy font-semibold truncate text-sm">{item.artist}</h3>
              <p class="text-xs text-slate-400 mt-1">
                Fans of <span class="text-slate-500">{item.sourceArtist}</span>
              </p>
            </div>
          ))}
        </div>
      </section>
    )}

    {/* Empty State */}
    {!hasData && (
      <div class="empty-state">
        <span class="text-4xl block mb-3" aria-hidden="true">♫</span>
        <p class="text-slate-400 text-lg font-heading">Nothing here yet</p>
        <p class="text-slate-400 text-sm mt-2 max-w-md mx-auto">
          Recommendations are generated every Monday morning.
          You can also trigger them manually from the GitHub Actions tab.
        </p>
        <p class="text-xs text-slate-300 mt-4 font-mono">
          $ next_run: Monday 04:00 UTC
        </p>
      </div>
    )}
  </main>

  <footer class="mt-16 pt-8 border-t border-slate-200 text-xs text-slate-400">
    <span>Powered by {isHybrid ? 'Spotify + Last.fm Hybrid Engine' : isLegacySpotify ? 'Spotify Recommendations API' : isFallback ? 'Last.fm Similarity Engine' : 'GitHub Actions'}</span>
  </footer>
</Layout>
