---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { readFileSync } from 'fs';

let recs = null;
try {
  recs = JSON.parse(readFileSync('./data/recommendations.json', 'utf-8'));
} catch {
  console.warn('recommendations.json not found');
}

const generatedDate = recs?.generatedAt
  ? new Date(recs.generatedAt).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const isSpotify = !recs?.source; // Spotify data doesn't have a 'source' field
const isFallback = recs?.source === 'lastfm_fallback';

// For Spotify: all tracks are proper track recommendations
// For Last.fm fallback: separate track-based and artist-based
const trackRecs = isSpotify 
  ? (recs?.tracks || [])
  : (recs?.tracks?.filter(t => t.name && t.sourceTrack) || []);
  
const artistRecs = isSpotify 
  ? []
  : (recs?.tracks?.filter(t => !t.name && t.sourceArtist) || []);

function isPlaceholderImage(url) {
  return !url || url.includes('2a96cbd8b46e442fc41c2b86b821562f');
}

function getInitials(name) {
  return name?.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase() || '?';
}
---

<Layout title="recommendations">
  <Navigation />

  <main class="space-y-10">
    {/* Header */}
    <section>
      <div class="flex items-center gap-3 mb-2">
        <span class="text-phosphor text-xl font-bold">$</span>
        <h1 class="text-2xl font-bold phosphor-glow">weekly_recommendations</h1>
      </div>
      <p class="text-text-dim text-sm">
        {generatedDate
          ? `Generated on ${generatedDate} based on your recent listening.`
          : 'No recommendations generated yet. They update every Monday.'}
      </p>
      {recs?.seedArtists?.length > 0 && (
        <p class="text-xs text-text-dim mt-2">
          Seed artists: {recs.seedArtists.join(', ')}
        </p>
      )}
    </section>

    {/* Engine Info Banner */}
    <div class:list={[
      "border p-4 text-sm",
      isSpotify ? "border-amber/30 bg-amber/5" : "border-phosphor-dim/30 bg-phosphor-dim/5"
    ]}>
      <div class="flex items-start gap-3">
        <span class="text-lg shrink-0">{isSpotify ? '🎯' : '♫'}</span>
        <div>
          <p class="font-bold text-phosphor mb-1">
            {isSpotify ? 'Spotify Algorithmic Recommendations' : 'Last.fm Similarity Engine (Fallback)'}
          </p>
          <p class="text-text-dim leading-relaxed">
            {isSpotify
              ? 'These are generated by Spotify\'s audio analysis engine. It examines acoustic features (danceability, energy, tempo, valence) and collaborative filtering to find music you probably haven\'t heard yet. Rich album art and 30-second previews included.'
              : 'These are generated by Last.fm\'s similarity graph. "Similar Tracks" are songs frequently played by listeners who also played your top tracks. "Similar Artists" are musicians closely connected in the Last.fm listener network. Images are limited because Last.fm doesn\'t provide album art for similar items.'
            }
          </p>
          {isFallback && (
            <p class="text-text-dim text-xs mt-2">
              Want richer recommendations with real album art? Ask a friend with Spotify Premium to create a Spotify Developer app — the code automatically switches when you update the secrets.
            </p>
          )}
        </div>
      </div>
    </div>

    {recs?.tracks?.length > 0 ? (
      <>
        {/* Track Recommendations Section */}
        {trackRecs.length > 0 && (
          <section>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-amber text-lg">♫</span>
              <h2 class="text-lg font-bold amber-glow">
                {isSpotify ? 'Recommended Tracks' : 'Similar Tracks'}
              </h2>
              <span class="text-xs text-text-dim border border-terminal-border px-2 py-0.5">{trackRecs.length}</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {trackRecs.map((track, i) => (
                <div class:list={[
                  "border bg-terminal-panel p-4 hover:transition-colors group",
                  isSpotify ? "border-terminal-border hover:border-amber/50" : "border-terminal-border hover:border-phosphor-dim"
                ]}>
                  <div class="flex items-start gap-4">
                    {/* Image */}
                    {track.image && !isPlaceholderImage(track.image) ? (
                      <img
                        src={track.image}
                        alt={track.name}
                        class="w-16 h-16 object-cover border border-terminal-border group-hover:border-amber/50 transition-colors shrink-0"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-16 h-16 bg-terminal-bg border border-terminal-border flex flex-col items-center justify-center shrink-0">
                        <span class="text-amber text-lg font-bold">{getInitials(track.artist)}</span>
                        <span class="text-[8px] text-text-dim mt-0.5">{getInitials(track.name)}</span>
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2">
                        <span class="text-xs text-amber">#{i + 1}</span>
                        {track.spotifyUrl && (
                          <a
                            href={track.spotifyUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-xs text-phosphor-dim hover:text-phosphor border border-phosphor-dim hover:border-phosphor px-2 py-0.5 transition-colors shrink-0"
                          >
                            open ↗
                          </a>
                        )}
                      </div>
                      <h3 class="text-phosphor font-bold truncate mt-1 phosphor-glow">{track.name}</h3>
                      <p class="text-amber text-sm truncate">{track.artist}</p>
                      {track.album && (
                        <p class="text-text-dim text-xs truncate">{track.album}</p>
                      )}
                      {track.sourceTrack && (
                        <p class="text-text-dim text-xs truncate mt-1">
                          Because you listened to: <span class="text-phosphor-dim">{track.sourceTrack}</span>
                        </p>
                      )}
                      {track.previewUrl && (
                        <audio controls class="mt-2 w-full h-6 opacity-60 hover:opacity-100 transition-opacity" preload="none">
                          <source src={track.previewUrl} type="audio/mpeg" />
                        </audio>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Similar Artists Section (only for fallback) */}
        {!isSpotify && artistRecs.length > 0 && (
          <section>
            <div class="flex items-center gap-3 mb-4">
              <span class="text-phosphor text-lg">👤</span>
              <h2 class="text-lg font-bold phosphor-glow">Similar Artists</h2>
              <span class="text-xs text-text-dim border border-terminal-border px-2 py-0.5">{artistRecs.length}</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
              {artistRecs.map((track, i) => (
                <div class="border border-terminal-border bg-terminal-panel p-4 hover:border-phosphor-dim transition-colors text-center group">
                  <div class="w-20 h-20 bg-terminal-bg border border-terminal-border flex items-center justify-center mx-auto mb-3 group-hover:border-phosphor-dim transition-colors">
                    <span class="text-2xl font-bold text-phosphor">{getInitials(track.artist)}</span>
                  </div>
                  <h3 class="text-amber font-bold truncate text-sm amber-glow">{track.artist}</h3>
                  <p class="text-text-dim text-[10px] mt-1 truncate">
                    Fans of <span class="text-phosphor-dim">{track.sourceArtist}</span>
                  </p>
                </div>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <div class="border border-terminal-border bg-terminal-panel p-8 text-center">
        <span class="text-4xl block mb-4">♫</span>
        <p class="text-text-dim">No recommendations available yet.</p>
        <p class="text-text-dim text-sm mt-2">Check back after the next weekly update.</p>
      </div>
    )}
  </main>

  <footer class="mt-16 pt-8 border-t border-terminal-border text-xs text-text-dim">
    <span>Powered by {isSpotify ? 'Spotify Recommendations API' : 'Last.fm Similarity Engine (fallback)'}</span>
  </footer>
</Layout>
