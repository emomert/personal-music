---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { readFileSync } from 'fs';

let lastfm = null;
try {
  lastfm = JSON.parse(readFileSync('./data/lastfm.json', 'utf-8'));
} catch {}

const recentTrack = lastfm?.recentTracks?.[0];
const isNowPlaying = recentTrack?.['@attr']?.nowplaying === 'true';
const totalScrobbles = Number(lastfm?.userInfo?.playcount || 0);
const topArtist7 = lastfm?.topArtists_last7days?.[0];
const topTrack7 = lastfm?.topTracks_last7days?.[0];

function getImage(images, size = 'large') {
  if (!images || !Array.isArray(images)) return null;
  const img = images.find(i => i.size === size);
  return img?.['#text'] || null;
}

function isPlaceholder(url) {
  return !url || url.includes('2a96cbd8b46e442fc41c2b86b821562f');
}

const heroImage = getImage(recentTrack?.image, 'extralarge') || getImage(recentTrack?.image, 'large');
const recentTracks = lastfm?.recentTracks?.slice(0, 15) || [];
---

<Layout title="Now Playing & Stats" description="Personal music dashboard — track listening history and discover new music">
  <Navigation />

  <main class="space-y-8 md:space-y-12 animate-section">
    {/* Hero */}
    <section class="card p-6 md:p-8">
      <div class="flex flex-col md:flex-row gap-6 items-start">
        {recentTrack && !isPlaceholder(heroImage) ? (
          <img
            src={heroImage}
            alt={`Album art for ${recentTrack.name} by ${recentTrack.artist?.['#text'] || recentTrack.artist}`}
            class="album-frame-lg w-36 h-36 md:w-44 md:h-44 object-cover shrink-0"
          />
        ) : (
          <div class="w-36 h-36 md:w-44 md:h-44 bg-cream-dark rounded-[6px] flex items-center justify-center shrink-0 border border-slate-200">
            <span class="text-4xl text-slate-300">♫</span>
          </div>
        )}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-medium text-slate-500 uppercase tracking-widest">Status</span>
            {isNowPlaying && (
              <span class="badge badge-spotify">● Live</span>
            )}
          </div>
          {recentTrack ? (
            <>
              <h2 class="text-2xl md:text-3xl font-heading font-semibold text-navy leading-tight">
                {recentTrack.name}
              </h2>
              <p class="text-lg text-amber-500 font-medium mt-2">
                {recentTrack.artist?.['#text'] || recentTrack.artist}
              </p>
              <p class="text-sm text-slate-500 mt-1">
                {recentTrack.album?.['#text'] || 'Unknown Album'}
              </p>
            </>
          ) : (
            <div class="empty-state">
              <p class="text-slate-400 text-lg font-heading">No recent tracks yet</p>
              <p class="text-slate-400 text-sm mt-2">Data will appear after the first GitHub Actions daily fetch.</p>
            </div>
          )}
          <div class="mt-6 pt-4 border-t border-slate-200 flex items-center gap-2 text-xs text-slate-400 font-mono">
            <span class="text-amber-500">$</span>
            <span>{isNowPlaying ? 'now_playing' : 'last_played'}</span>
          </div>
        </div>
      </div>
    </section>

    {/* Stats Grid */}
    <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="card p-5">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-widest block mb-2">Total Scrobbles</span>
        <span class="text-3xl font-bold text-navy stat-number animate-count-up">{totalScrobbles.toLocaleString()}</span>
      </div>
      <div class="card p-5">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-widest block mb-2">Top Artist (7d)</span>
        <span class="text-xl font-heading font-semibold text-navy truncate block">{topArtist7?.name || '—'}</span>
        {topArtist7?.playcount && (
          <span class="text-xs text-slate-400 mt-1 block">{Number(topArtist7.playcount).toLocaleString()} plays</span>
        )}
      </div>
      <div class="card p-5">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-widest block mb-2">Top Track (7d)</span>
        <span class="text-xl font-heading font-semibold text-navy truncate block">{topTrack7?.name || '—'}</span>
        {topTrack7?.artist && (
          <span class="text-xs text-slate-400 mt-1 block">{topTrack7.artist?.name || topTrack7.artist?.['#text']}</span>
        )}
      </div>
    </section>

    {/* Recent History */}
    <section>
      <h2 class="text-xl font-heading font-semibold text-navy mb-4">Recent History</h2>
      <div class="card overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase w-12">#</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase w-12"></th>
              <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Track</th>
              <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase hidden sm:table-cell">Artist</th>
              <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase w-20">Time</th>
            </tr>
          </thead>
          <tbody>
            {recentTracks.map((track, i) => {
              const img = getImage(track.image, 'small');
              const time = track.date
                ? new Date(track.date.uts * 1000).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                : 'now';
              return (
                <tr class="border-b border-slate-100 last:border-b-0 hover:bg-cream-dark/50 transition-colors duration-150">
                  <td class="px-4 py-3 text-sm text-slate-400 font-mono">{(i + 1).toString().padStart(2, '0')}</td>
                  <td class="px-4 py-3">
                    {img && !isPlaceholder(img) ? (
                      <img src={img} alt="" class="w-8 h-8 rounded object-cover album-frame" loading="lazy" />
                    ) : (
                      <div class="w-8 h-8 bg-cream-dark rounded flex items-center justify-center"><span class="text-xs text-slate-300" aria-hidden="true">♫</span></div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-sm text-navy font-medium truncate max-w-[120px] sm:max-w-none">{track.name}</td>
                  <td class="px-4 py-3 text-sm text-slate-600 truncate max-w-[100px] hidden sm:table-cell">{track.artist?.['#text'] || track.artist}</td>
                  <td class="px-4 py-3 text-sm text-slate-400 text-right font-mono">{time}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <div class="mt-4 text-right">
        <a href="/dashboard" class="inline-flex items-center gap-2 text-sm font-medium text-navy hover:text-amber-500 transition-colors duration-150">
          View full dashboard
          <span class="text-lg leading-none">→</span>
        </a>
      </div>
    </section>
  </main>

  <footer class="mt-16 pt-8 border-t border-slate-200 text-xs text-slate-400">
    <div class="flex flex-col sm:flex-row justify-between gap-2">
      <span>Data sources: Last.fm &middot; ListenBrainz &middot; Spotify</span>
      <span>Updated daily via GitHub Actions</span>
    </div>
  </footer>
</Layout>

<script>
  // Animate stat numbers
  document.querySelectorAll('.animate-count-up').forEach(el => {
    el.style.animationDelay = '200ms';
  });
</script>
